# Required: Google Gemini API key
GEMINI_API_KEY=AIzaSyDpH8vWHdaWMWlIHdsBdi8uhBCm_4uiYGw

# Required: Neon PostgreSQL database
DATABASE_URL=postgresql://user:password@your-neon-host/neondb?sslmode=require

# Required in production: use a long random value
JWT_SECRET=replace_with_a_long_random_secret

# Optional: comma-separated model fallback order
# Project uses this order when no GEMINI_MODELS is provided:
# gemini-2.5-flash,gemini-2.5-flash-latest,gemini-2.0-flash,gemini-2.0-flash-lite,gemini-1.5-flash-latest,gemini-1.5-flash,gemini-1.5-flash-8b-latest,gemini-1.5-flash-8b
GEMINI_MODELS=

# Optional: route-specific model fallback order
ANALYZE_GEMINI_MODELS=
RECIPE_GEMINI_MODELS=
RECIPE_ASSISTANT_GEMINI_MODELS=

# Optional: allow sample fallback data when Gemini quota is exceeded
ALLOW_QUOTA_FALLBACK=false
